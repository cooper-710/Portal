NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY (server-only — NEVER expose to the browser)
# ---------------------------------------------------------------------------
# Required for Stripe webhooks and other server paths with no user session.
# Bypasses RLS to update invoices, users (Connect / Portal Pro), etc.
# Get it from: Supabase Dashboard → Project Settings → API → service_role
# DO NOT prefix with NEXT_PUBLIC_ — that would ship the key to every client.
# If this is missing, /api/webhooks/stripe returns 500 and will not mark
# payments or subscriptions as synced.
# Production: set in Vercel → Settings → Environment Variables (Production).
# Rotate immediately if this key was ever committed, pasted in chat, or logged.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Stripe — use sk_test_ / pk_test_ locally; sk_live_ / pk_live_ in production
# ---------------------------------------------------------------------------
# Never commit live keys. Switch Dashboard to Live mode for production values.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# STRIPE_WEBHOOK_SECRET (required for webhook signature verification)
# ---------------------------------------------------------------------------
# Used with stripe.webhooks.constructEvent on the raw request body.
# Unsigned or invalid signatures are rejected (400); a missing secret
# rejects the request (503) — events are never processed without verification.
# Local: `stripe listen --forward-to localhost:3001/api/webhooks/stripe`
#         → copy the printed whsec_... value here
# Production: Stripe Dashboard (Live) → Developers → Webhooks
#   Endpoint URL: https://YOUR_DOMAIN/api/webhooks/stripe
#   Events: checkout.session.completed, customer.subscription.*, account.updated
#   → copy the endpoint signing secret (whsec_...) here
STRIPE_WEBHOOK_SECRET=

# Platform SaaS subscription (monthly Price ID for freelancers)
# Local/test: create a $25/mo Price in Stripe Test mode
# Production: create the same Price in Live mode and paste price_...
STRIPE_SAAS_PRICE_ID=price_...
# Portal Pro free trial length (days). Used as Checkout subscription_data.trial_period_days.
PORTAL_PRO_TRIAL_DAYS=14
# Stripe Trial Offer ID from Dashboard (to_…). Checkout cannot attach trial offers;
# kept for reference / future Subscriptions API use. Duration is applied via PORTAL_PRO_TRIAL_DAYS.
STRIPE_TRIAL_OFFER_ID=to_...
# Connect destination charges — platform application fee on client invoice payments
# Percent of invoice (default 1 if neither percent nor flat is set). Example: 1 = 1%
STRIPE_PLATFORM_FEE_PERCENT=1
# Optional flat fee in cents added on top of the percent. Example: 500 = $5
# STRIPE_PLATFORM_FEE_FLAT_CENTS=0
# Enable Stripe Connect (Express) in the Stripe Dashboard (test + live).
# Freelancers onboard via /dashboard/invoices → Connect Stripe.
# Checkout uses destination charges + application_fee_amount to the platform.
# Enable Customer Portal in Stripe for subscription management.

# Resend — project invite emails (app). Separate from Supabase Auth SMTP.
# Without a verified domain, Resend only delivers to your Resend account email.
# Use beth.t@example.com for that testing; switch to noreply@YOUR_DOMAIN after verify.
# Auth confirmation emails need Supabase Dashboard → SMTP (see docs/AUTH_EMAIL.md).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Portal <beth.t@example.com>

# Public site URL used for Checkout success/cancel redirects and auth emails.
# Local: http://localhost:3001
# Production: https://YOUR_DOMAIN  (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Optional — error tracking (not required for launch; leave unset to skip)
# SENTRY_DSN=
