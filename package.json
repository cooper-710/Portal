    "next": "15.5.20",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.22",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.17.2",
    "sharp": "^0.35.3",
